rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Notes are written only via the createNoteCallable cloud function (admin SDK bypasses rules).
    // Reads are open so the web client can list notes without authentication.
    match /notes/{noteId} {
      allow read: if true;
      allow write: if false;
    }
    // Canon items — shared ingredient canon; any authenticated user can read and write.
    match /canonItems/{itemId} {
      allow read, write: if request.auth != null;
    }
    // Aisle config — shared; any authenticated user can read and write.
    match /canonData/{document} {
      allow read, write: if request.auth != null;
    }
    // Equipment manifest — single doc, shared; any authenticated user can read and write.
    match /equipmentManifest/{document} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
