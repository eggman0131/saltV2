# Isolated Vitest emulator stack ports (issue #84, Phase 3).
#
# Loaded by Vite/Vitest (mode=test) and exposed on import.meta.env, which
# init.ts / auth.ts / tests/emulatorHelpers.ts read to target the isolated
# Vitest stack instead of the dev emulator. These MUST match the host port
# mappings in docker/test-emulators/docker-compose.vitest.yml (the authoritative
# source for the stack's ports). Not gitignored (only .env / .env.local /
# .env.*.local are) so it is committed and CI-safe.
VITE_EMULATOR_FIRESTORE_PORT=8082
VITE_EMULATOR_AUTH_PORT=9101
