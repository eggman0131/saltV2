{
  "name": "@salt/ui-components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./headless": "./src/headless.ts",
    "./tokens": "./src/tokens.ts",
    "./styles.css": "./src/salt.css",
    "./test": "./src/test.ts"
  },
  "scripts": {
    "test": "vitest run",
    "check": "svelte-check --tsconfig ./tsconfig.json",
