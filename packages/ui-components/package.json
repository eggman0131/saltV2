    "provenance:check": "tsx scripts/check-provenance.ts",
    "theme:check": "tsx scripts/check-theme.ts"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.0",
    "@lucide/svelte": "^1.23.0",
    "bits-ui": "^2.18.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "svelte": "^5.56.4",
    "svelte-dnd-action": "^0.9.70",
    "svelte-easy-crop": "^5.0.1",
    "svelte-exmarkdown": "^5.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.5.0",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "vitest-axe": "^0.1.0"
  }
