{
  "name": "salt",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint \"**/*.{ts,js}\"",
    "lint:boundaries": "eslint \"packages/**/*.ts\" \"apps/**/*.ts\" \".boundary-tests/**/*.ts\"",
    "typecheck": "tsc --build",
    "boundary:test": "sh .boundary-tests/run.sh",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,js,svelte,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,js,svelte,css,html}\"",
    "dev:emulators": "firebase emulators:start"
  },
  "lint-staged": {
    "*.{ts,js,svelte}": [
      "eslint --no-error-on-unmatched-pattern",
      "prettier --check"
    ],
    "*.{css,html}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "dependency-cruiser": "^16.9.0",
    "eslint": "^9.26.0",
    "eslint-plugin-boundaries": "^4.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "typescript": "^5.8.3",
    "firebase-tools": "^15.12.0",
    "vitest": "^3.2.0"
  }
}
