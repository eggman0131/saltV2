{
  "name": "salt",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint \"**/*.{ts,js,svelte}\"",
    "lint:boundaries": "eslint \"packages/**/*.ts\" \"apps/**/*.ts\" \".boundary-tests/**/*.ts\"",
    "typecheck": "tsc --build && tsc -p apps/web-pwa/e2e/tsconfig.json",
    "check": "pnpm -r --if-present check",
    "boundary:test": "sh .boundary-tests/run.sh",
    "depcruise": "depcruise --config .dependency-cruiser.cjs packages apps",
    "provenance:check": "pnpm --filter @salt/ui-components provenance:check",
    "theme:check": "pnpm --filter @salt/ui-components theme:check",
    "release": "bash scripts/cut-release.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"**/*.{ts,js,svelte,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,js,svelte,css,html}\"",
    "dev": "node scripts/sync-worktree-env.mjs && node scripts/free-ports.mjs 5173 && exec pnpm --filter @salt/web-pwa dev",
    "dev:genkit": "node scripts/sync-worktree-env.mjs && node scripts/free-ports.mjs 4001 4033 3100 && exec pnpm --filter @salt/cloud-functions dev",
    "dev:emulators": "node scripts/sync-worktree-env.mjs && node scripts/stop-emulators.mjs && pnpm --filter @salt/cloud-functions build && (cp apps/cloud-functions/.secret.local apps/cloud-functions/dist/.secret.local 2>/dev/null || true) && (node scripts/seed-emulator-admin.mjs &) && exec env NODE_OPTIONS='--disable-warning=DEP0040' GENKIT_ENV=dev GENKIT_TELEMETRY_SERVER=http://localhost:4033 firebase emulators:start --only firestore,auth,functions,storage --import=./.emulator-data --export-on-exit=./.emulator-data",
    "stop:emulators": "node scripts/stop-emulators.mjs",
    "test:emulator": "node scripts/test-emulator.mjs"
  },
  "lint-staged": {
    "*.{ts,js,svelte}": [
      "prettier --write",
      "eslint --no-error-on-unmatched-pattern"
    ],
    "*.{css,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "esbuild",
      "protobufjs",
      "re2",
      "sharp"
    ],
    "overrides": {
      "@opentelemetry/api": "1.9.0",
      "@tootallnate/once": "^2.0.1",
      "esbuild": "^0.28.1",
      "fast-xml-parser": "^5.8.0",
      "firebase-admin>uuid": "^11.1.1",
      "form-data@>=4.0.0 <4.0.6": "^4.0.6",
      "hono": "^4.12.25",
      "js-yaml@4": "^4.2.0",
      "protobufjs": "^7.6.4",
      "qs": "^6.15.2",
      "tar": "^7.5.16",
      "tmp": "^0.2.6"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-boundaries": "^7.0.1",
    "eslint-plugin-playwright": "^2.10.5",
    "firebase-tools": "^15.22.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
