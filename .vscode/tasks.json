{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Stop Firebase Emulators",
      "detail": "Gracefully stop the emulators (runs export-on-exit so dev data is preserved). Use this instead of the terminate button on the 'Firebase Emulators' task — terminating that task signals only the top of the process tree and does NOT reach firebase, so the export never runs.",
      "type": "shell",
      "command": "pnpm",
      "args": ["stop:emulators"],
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "close": false,
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Firebase Emulators",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:emulators"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "firebase emulators:start",
          "endsPattern": "All emulators ready"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "close": false,
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Vite Dev Server",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:.*http"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Genkit Admin UI",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:genkit"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "genkit start",
          "endsPattern": "Genkit Developer UI:.*http://localhost:4001"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Export Prod Firestore",
      "detail": "Read-only: export the PRODUCTION Firestore database to GCS. Safe half of the prod -> staging refresh; pair with 'Restore Staging from Prod'. No triggers fire; blocks until done.",
      "type": "shell",
      "command": "node",
      "args": ["scripts/export-prod-firestore.mjs"],
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "Restore Staging from Prod",
      "detail": "DESTRUCTIVE: wipes staging Firestore and restores it from the newest prod export. Requires typing STAGING to confirm; refuses to target prod. Run 'Export Prod Firestore' first.",
      "type": "shell",
      "command": "node",
      "args": ["scripts/restore-staging-from-prod.mjs"],
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "Export Staging Firestore",
      "detail": "Read-only: export the STAGING Firestore database to GCS. Safe half of the staging -> dev refresh; pair with 'Restore Dev from Staging'. No triggers fire; blocks until done.",
      "type": "shell",
      "command": "node",
      "args": ["scripts/export-staging-firestore.mjs"],
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "Restore Dev from Staging",
      "detail": "DESTRUCTIVE: wipes dev-cloud Firestore and restores it from the newest staging export. Requires typing DEV to confirm; refuses to target prod or staging. Run 'Export Staging Firestore' first.",
      "type": "shell",
      "command": "node",
      "args": ["scripts/restore-dev-from-staging.mjs"],
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      }
    }
  ]
}
