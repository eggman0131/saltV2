{
  "name": "task-pilot-extension",
  "displayName": "Task Pilot",
  "description": "Sidebar controls for starting, stopping, restarting, and opening workspace dev services.",
  "version": "0.1.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskPilotContainer",
          "title": "Task Pilot",
          "icon": "media/tasks.svg"
        }
      ]
    },
    "views": {
      "taskPilotContainer": [
        {
          "id": "taskPilotView",
          "name": "Task Control"
        }
      ]
    },
    "commands": [
      {
        "command": "taskPilot.refresh",
        "title": "Task Pilot: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "taskPilot.startAll",
        "title": "Task Pilot: Start All",
        "icon": "$(run-all)"
      },
      {
        "command": "taskPilot.restartAll",
        "title": "Task Pilot: Restart All",
        "icon": "$(sync)"
      },
      {
        "command": "taskPilot.nuke",
        "title": "Task Pilot: Nuclear Stop (force-kill everything)",
        "icon": "$(flame)"
      },
      {
        "command": "taskPilot.toggle",
        "title": "Task Pilot: Toggle Task"
      },
      {
        "command": "taskPilot.start",
        "title": "Task Pilot: Start",
        "icon": "$(play)"
      },
      {
        "command": "taskPilot.stop",
        "title": "Task Pilot: Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "taskPilot.restart",
        "title": "Task Pilot: Restart",
        "icon": "$(debug-restart)"
      },
      {
        "command": "taskPilot.open",
        "title": "Task Pilot: Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "taskPilot.openTaskConfig",
        "title": "Task Pilot: Open tasks.json",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "taskPilot.startAll",
          "when": "view == taskPilotView",
          "group": "navigation@1"
        },
        {
          "command": "taskPilot.restartAll",
          "when": "view == taskPilotView",
          "group": "navigation@2"
        },
        {
          "command": "taskPilot.nuke",
          "when": "view == taskPilotView",
          "group": "navigation@3"
        },
        {
          "command": "taskPilot.refresh",
          "when": "view == taskPilotView",
          "group": "navigation@4"
        },
        {
          "command": "taskPilot.openTaskConfig",
          "when": "view == taskPilotView",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "taskPilot.stop",
          "when": "view == taskPilotView && viewItem == taskRunning",
          "group": "inline@1"
        },
        {
          "command": "taskPilot.restart",
          "when": "view == taskPilotView && viewItem == taskRunning",
          "group": "inline@2"
        },
        {
          "command": "taskPilot.open",
          "when": "view == taskPilotView && viewItem == taskRunning",
          "group": "inline@3"
        },
        {
          "command": "taskPilot.start",
          "when": "view == taskPilotView && viewItem == taskStopped",
          "group": "inline@1"
        },
        {
          "command": "taskPilot.openTaskConfig",
          "when": "view == taskPilotView && viewItem == taskMissing",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "Task Pilot",
      "properties": {
        "taskPilot.labels": {
          "type": "array",
          "description": "Task labels to show in the sidebar, in order. Defaults to Firebase, Vite, and Genkit tasks. Start All / Restart All act only on the long-running background services here; one-shot tasks (e.g. prod export, staging restore) stay listed and individually runnable but are excluded from bulk start/restart.",
          "items": {
            "type": "string"
          },
          "default": [
            "Firebase Emulators",
            "Vite Dev Server",
            "Genkit Admin UI"
          ]
        },
        "taskPilot.seedAdminMember": {
          "type": "boolean",
          "description": "After the Firebase Emulators task starts (or restarts) and Firestore is ready, seed the admin member so sign-in works against fresh emulator data.",
          "default": true
        },
        "taskPilot.seedAdminEmail": {
          "type": "string",
          "description": "Email of the admin member to seed into the Firestore emulator on start.",
          "default": "daniel@pendery.org"
        }
      }
    }
  }
}
