{
  "name": "@salt/web-pwa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "node ../../scripts/stop-emulators.mjs && playwright test",
    "e2e:coverage": "node ../../scripts/stop-emulators.mjs && playwright test && node --experimental-strip-types scripts/process-e2e-coverage.ts",
    "e2e:coverage:report": "node --experimental-strip-types scripts/process-e2e-coverage.ts",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:ui": "node ../../scripts/stop-emulators.mjs && playwright test --ui"
  },
  "dependencies": {
    "@salt/domain": "workspace:*",
    "@salt/firebase-sync": "workspace:*",
    "@salt/ld-observability": "workspace:*",
    "@salt/shared-types": "workspace:*",
    "@salt/ui-components": "workspace:*",
    "lucide-svelte": "^0.460.1",
    "svelte": "^5.55.0",
    "svelte-spa-router": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.0",
    "@testing-library/user-event": "^14.5.0",
    "autoprefixer": "^10.4.0",
    "axe-core": "^4.10.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^6.0.0",
    "vitest-axe": "^0.1.0"
  }
}
