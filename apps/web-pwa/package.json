{
  "name": "@salt/web-pwa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:dev": "vite build --mode dev",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "icons:generate": "node --experimental-strip-types scripts/generate-icons.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:coverage": "playwright test && node --experimental-strip-types scripts/process-e2e-coverage.ts",
    "e2e:coverage:report": "node --experimental-strip-types scripts/process-e2e-coverage.ts",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@salt/domain": "workspace:*",
    "@salt/firebase-sync": "workspace:*",
    "@salt/observability": "workspace:*",
    "@salt/shared-types": "workspace:*",
    "@salt/ui-components": "workspace:*",
    "leaflet": "^1.9.4",
    "svelte": "^5.56.4",
    "svelte-spa-router": "^5.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.5.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^8",
    "vite-plugin-pwa": "^1.3.0",
    "vitest-axe": "^0.1.0"
  }
}
