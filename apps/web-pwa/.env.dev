# App Check (issue #145) intentionally unset for dev: enforcement is monitor-first
# (server-side, non-blocking), and firebase.ts skips App Check init when the site
# key is empty. The dev hosting domain isn't registered with the reCAPTCHA key, so
# leaving it empty avoids attestation noise while keeping callables working.
VITE_FIREBASE_APPCHECK_SITE_KEY=
# PostHog (browser observability) — EU region, SAME project as staging/prod so the
# browser->CF->trigger trace chain is actually observable on dev (a core reason
# this env exists). An empty key makes the observability adapter a complete no-op.
VITE_PUBLIC_POSTHOG_KEY=phc_qw73ZuXRSy6VBhZhVLRqaiNfVEB9kektGLSAGUyLTf5x
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
VITE_USE_EMULATORS=false
# PWA install identity — dev is visually distinct from staging (sky-blue) and
# prod (orange): violet theme + its own name for at-a-glance tab clarity.
VITE_PWA_NAME=Salt (Dev)
VITE_PWA_SHORT_NAME=Salt Dev
VITE_PWA_THEME_COLOR="#7C3AED"
