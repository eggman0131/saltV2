{
  "name": "@salt/cloud-functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --external:firebase-admin --external:firebase-admin/* --external:firebase-functions --external:firebase-functions/* --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "genkit start --port 4001 -- tsx --env-file=.secret.local --watch src/dev.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:emulator": "vitest run --config vitest.emulator.config.ts"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "genkit-cli": "^1.33.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.33.0",
    "@opentelemetry/sdk-trace-node": "^1.25.1",
    "@salt/domain": "workspace:*",
    "@salt/ld-observability": "workspace:*",
    "@salt/shared-types": "workspace:*",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^7.2.5",
    "genkit": "^1.33.0"
  }
}
