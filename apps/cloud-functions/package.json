{
  "name": "@salt/cloud-functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --external:firebase-admin --external:firebase-admin/* --external:firebase-functions --external:firebase-functions/*",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "@salt/domain": "workspace:*",
    "@salt/firebase-sync": "workspace:*",
    "@salt/shared-types": "workspace:*",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^7.2.5"
  }
}
